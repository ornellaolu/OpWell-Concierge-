{
  "crons": [
    {
      "path": "/api/cron-daily-reminders",
      "schedule": "0 8 * * *"
    }
  ],
  "redirects": [
    { "source": "/provider.html", "destination": "/provider", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/patient-recovery-checkin.html", "destination": "/patient-recovery-checkin.html" },
    { "source": "/postop-recovery-checkin.html", "destination": "/postop-recovery-checkin.html" },
    { "source": "/admin-checkins.html", "destination": "/admin-checkins.html" },
    { "source": "/surgery-readiness-quiz.html", "destination": "/surgery-readiness-quiz.html" },
    { "source": "/surgery-prep-masterclass.html", "destination": "/surgery-prep-masterclass.html" },
    { "source": "/masterclass", "destination": "/surgery-prep-masterclass.html" },
    { "source": "/ad-landing.html", "destination": "/ad-landing.html" },
    { "source": "/welcome", "destination": "/ad-landing.html" },
    { "source": "/provider", "destination": "/index.html" },
    { "source": "/provider.html", "destination": "/index.html" },
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/recovery-checkin", "destination": "/index.html" },
    { "source": "/:file*.png", "destination": "/:file*.png" },
    { "source": "/:file*.jpg", "destination": "/:file*.jpg" },
    { "source": "/:file*.pdf", "destination": "/:file*.pdf" },
    { "source": "/:file*.svg", "destination": "/:file*.svg" },
    { "source": "/:file*.ico", "destination": "/:file*.ico" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
